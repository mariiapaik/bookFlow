# ---- Server ----
PORT=3000
CORS_ORIGIN=http://localhost:5173
SALON_NAME=Bloom Beauty Studio
SALON_TIMEZONE=Europe/Berlin

# ---- Database (Postgres) ----
# Either set DATABASE_URL, or the discrete DB_* vars below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=bookflow
DB_PASSWORD=bookflow
DB_NAME=bookflow

# ---- Redis (BullMQ) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- Auth ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES=12h

# ---- Email (Nodemailer) ----
# Leave SMTP_HOST empty to log emails to console instead of sending (demo mode).
MAIL_FROM=Bloom Beauty <no-reply@bookflow.app>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
